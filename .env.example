# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the MOC Part Matcher.
# Copy to .env.local for local dev. In Vercel, add these under
# Project → Settings → Environment Variables. NONE of these are needed for the
# Plan 1 engine/eval (CI runs with zero secrets) — they come online in Plan 2+.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key for the live AI adjudicator (Plan 2). Server-side ONLY —
# never expose to the client. Create at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Model id for the adjudicator. Defaults to a current Claude model in code if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Neon Postgres connection string (Plan 2). Auto-injected when you add Neon via the
# Vercel Marketplace (Storage → Neon). For local dev, paste a pooled connection string.
DATABASE_URL=

# Admin secret to gate destructive actions (replaces the legacy hardcoded PIN).
# Server-side ONLY.
ADMIN_SECRET=
